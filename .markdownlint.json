{
	"code-block-style": {
		"style": "fenced"
	},
	"code-fence-style": {
		"style": "backtick"
	},
	"emphasis-style": {
		"style": "underscore"
	},
	"extends": "markdownlint/style/prettier",
	"first-line-h1": false,
	"no-bare-urls": false,
	"no-duplicate-heading": {
		"siblings_only": true
	},
	"no-inline-html": false,
	"strong-style": {
		"style": "asterisk"
	},
	"ul-style": {
		"style": "dash"
	}
}
